generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdProducts Product[] @relation("ProductCreatedBy")
  updatedProducts Product[] @relation("ProductUpdatedBy")
}

enum ProductType {
  MATERIAL
  FINISHED
}

enum UnitOfMeasure {
  UNIT
  KG
  G
  M
  CM
  L
  ML
  PACKAGE
  ROLL
}

model Product {
  id           String        @id @default(cuid())
  sku          String        @unique
  name         String
  type         ProductType
  unit         UnitOfMeasure
  description  String?
  barcode      String?
  unitCost     Decimal?      @db.Decimal(12, 2)
  defaultPrice Decimal?      @db.Decimal(12, 2)
  minStock     Decimal?      @db.Decimal(14, 3)
  imageUrl     String?
  notes        String?
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  createdById String
  createdBy   User   @relation("ProductCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedById String
  updatedBy   User   @relation("ProductUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  @@index([type])
  @@index([active])
}
