generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdProducts Product[] @relation("ProductCreatedBy")
  updatedProducts Product[] @relation("ProductUpdatedBy")

  createdWarehouses Warehouse[] @relation("WarehouseCreatedBy")
  updatedWarehouses Warehouse[] @relation("WarehouseUpdatedBy")

  createdStockMovements StockMovement[] @relation("StockMovementCreatedBy")
  updatedStockMovements StockMovement[] @relation("StockMovementUpdatedBy")

  createdBankAccounts BankAccount[] @relation("BankAccountCreatedBy")
  updatedBankAccounts BankAccount[] @relation("BankAccountUpdatedBy")

  createdFinancialCategories FinancialCategory[] @relation("FinancialCategoryCreatedBy")
  updatedFinancialCategories FinancialCategory[] @relation("FinancialCategoryUpdatedBy")

  createdFinancialEntries FinancialEntry[] @relation("FinancialEntryCreatedBy")
  updatedFinancialEntries FinancialEntry[] @relation("FinancialEntryUpdatedBy")

  createdCompositions Composition[] @relation("CompositionCreatedBy")
  updatedCompositions Composition[] @relation("CompositionUpdatedBy")
}

enum ProductType {
  MATERIAL
  FINISHED
}

enum UnitOfMeasure {
  UNIT
  KG
  G
  M
  CM
  L
  ML
  PACKAGE
  ROLL
}

model Product {
  id           String        @id @default(cuid())
  sku          String        @unique
  name         String
  type         ProductType
  unit         UnitOfMeasure
  description  String?
  barcode      String?
  unitCost     Decimal?      @db.Decimal(12, 2)
  defaultPrice Decimal?      @db.Decimal(12, 2)
  minStock     Decimal?      @db.Decimal(14, 3)
  imageUrl     String?
  notes        String?
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  createdById String
  createdBy   User   @relation("ProductCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedById String
  updatedBy   User   @relation("ProductUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  stockBalances  StockBalance[]
  stockMovements StockMovement[]

  compositionsAsFinished     Composition[]     @relation("CompositionFinishedProduct")
  compositionItemsAsMaterial CompositionItem[] @relation("CompositionItemMaterial")

  @@index([type])
  @@index([active])
}

model Warehouse {
  id        String  @id @default(cuid())
  code      String  @unique
  name      String
  location  String?
  isDefault Boolean @default(false)
  active    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String
  createdBy   User   @relation("WarehouseCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedById String
  updatedBy   User   @relation("WarehouseUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  stockBalances      StockBalance[]
  stockMovementsFrom StockMovement[] @relation("StockMovementFrom")
  stockMovementsTo   StockMovement[] @relation("StockMovementTo")

  @@index([active])
}

enum StockMovementType {
  MANUAL_IN
  MANUAL_OUT
  ADJUST_IN
  ADJUST_OUT
  TRANSFER_OUT
  TRANSFER_IN
  PRODUCTION_CONSUME
  PRODUCTION_IN
  SALE_OUT
  REVERSAL
}

enum StockMovementSourceType {
  SALE
  PRODUCTION
  TRANSFER
  ADJUSTMENT
}

model StockBalance {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  quantity    Decimal   @default(0) @db.Decimal(14, 3)

  @@unique([productId, warehouseId])
}

model StockMovement {
  id   String            @id @default(cuid())
  type StockMovementType
  date DateTime          @default(now())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity  Decimal @db.Decimal(14, 3)

  fromWarehouseId String?
  fromWarehouse   Warehouse? @relation("StockMovementFrom", fields: [fromWarehouseId], references: [id], onDelete: Restrict)
  toWarehouseId   String?
  toWarehouse     Warehouse? @relation("StockMovementTo", fields: [toWarehouseId], references: [id], onDelete: Restrict)

  reason String
  notes  String?

  sourceType StockMovementSourceType?
  sourceId   String?

  reversalOfId String?        @unique
  reversalOf   StockMovement? @relation("MovementReversal", fields: [reversalOfId], references: [id], onDelete: Restrict)
  reversedBy   StockMovement? @relation("MovementReversal")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String
  createdBy   User   @relation("StockMovementCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedById String
  updatedBy   User   @relation("StockMovementUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  @@index([productId])
  @@index([type])
  @@index([date])
}

enum BankAccountType {
  CHECKING
  SAVINGS
  CASH
  OTHER
}

model BankAccount {
  id                 String          @id @default(cuid())
  name               String
  institution        String?
  type               BankAccountType
  initialBalance     Decimal         @db.Decimal(12, 2)
  initialBalanceDate DateTime
  notes              String?
  active             Boolean         @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String
  createdBy   User   @relation("BankAccountCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedById String
  updatedBy   User   @relation("BankAccountUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  financialEntries FinancialEntry[]

  @@index([active])
}

enum FinancialEntryKind {
  INCOME
  EXPENSE
}

enum FinancialEntryOrigin {
  SIMPLE
  SALE
}

model FinancialCategory {
  id     String             @id @default(cuid())
  name   String
  kind   FinancialEntryKind
  active Boolean            @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String
  createdBy   User   @relation("FinancialCategoryCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedById String
  updatedBy   User   @relation("FinancialCategoryUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  entries FinancialEntry[]

  @@unique([name, kind])
  @@index([kind])
  @@index([active])
}

model FinancialEntry {
  id          String               @id @default(cuid())
  kind        FinancialEntryKind
  origin      FinancialEntryOrigin @default(SIMPLE)
  description String
  amount      Decimal              @db.Decimal(12, 2)

  competenceDate DateTime
  dueDate        DateTime?

  // Data de recebimento (kind=INCOME) ou de pagamento (kind=EXPENSE). Nula = pendente,
  // preenchida = recebida/paga — não existe um status separado para isso (evita duplicidade
  // entre estado e data).
  settledAt DateTime?

  categoryId String
  category   FinancialCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  // Obrigatória no service quando settledAt está preenchido; opcional enquanto pendente.
  bankAccountId String?
  bankAccount   BankAccount? @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)

  // Estado operacional de cancelamento, independente da situação financeira (settledAt).
  cancelledAt DateTime?

  sourceId String?
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String
  createdBy   User   @relation("FinancialEntryCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedById String
  updatedBy   User   @relation("FinancialEntryUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  @@index([kind])
  @@index([settledAt])
  @@index([cancelledAt])
  @@index([bankAccountId])
  @@index([categoryId])
}

// Uma composição ativa por produto final (RF-CMP-003): para trocar os materiais de um
// produto, inative a composição atual e crie uma nova — não há edição in-place, então
// produções passadas (F2.2) que guardam cópia dos itens usados nunca são afetadas.
model Composition {
  id                 String  @id @default(cuid())
  finishedProductId  String
  finishedProduct    Product @relation("CompositionFinishedProduct", fields: [finishedProductId], references: [id], onDelete: Restrict)
  active             Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String
  createdBy   User   @relation("CompositionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedById String
  updatedBy   User   @relation("CompositionUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  items CompositionItem[]

  @@index([finishedProductId])
  @@index([active])
}

model CompositionItem {
  id                String      @id @default(cuid())
  compositionId     String
  composition       Composition @relation(fields: [compositionId], references: [id], onDelete: Cascade)
  materialProductId String
  materialProduct   Product     @relation("CompositionItemMaterial", fields: [materialProductId], references: [id], onDelete: Restrict)
  quantity          Decimal     @db.Decimal(14, 3)

  @@unique([compositionId, materialProductId])
}
